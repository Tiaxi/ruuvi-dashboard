# Ruuvi Dashboard configuration
# Copy this file to .env and customize as needed.
# All values shown are defaults — you only need to set what you want to change.

# Dashboard title (used in Grafana tab and dashboard header)
DASHBOARD_TITLE=Ruuvi Dashboard

# Public Grafana URL as seen by browsers. For a reverse proxy, set this to
# the external HTTPS URL, e.g. https://saa.example.com/.
GRAFANA_ROOT_URL=http://localhost:3000/

# Public Grafana hostname used for domain enforcement.
GRAFANA_DOMAIN=localhost

# Serve Grafana under a subpath (e.g. /grafana/) for reverse proxy setups.
# Leave empty for root path. If set, include leading and trailing slashes and
# include the same path in GRAFANA_ROOT_URL.
GRAFANA_SUBPATH=

# Admin UI host port (collector listens on 8000 inside container)
ADMIN_PORT=8000

# Grafana host port
GRAFANA_PORT=3000

# Grafana admin password (only used on first start)
GF_ADMIN_PASSWORD=admin

# VictoriaMetrics data retention period
VM_RETENTION=1y
